{
  "name": "am-ghareeb-server",
  "version": "1.0.0",
  "description": "Am Ghareeb — Alexandria microbus advisor API",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --runInBand --detectOpenHandles",
    "seed": "node src/scripts/seed.js"
  },
  "dependencies": {
    "express": "4.18.2",
    "mongoose": "8.0.3",
    "bcryptjs": "2.4.3",
    "jsonwebtoken": "9.0.2",
    "passport": "0.7.0",
    "passport-google-oauth20": "2.0.0",
    "openai": "4.28.0",
    "cors": "2.8.5",
    "dotenv": "16.4.1",
    "express-rate-limit": "7.2.0",
    "joi": "17.12.1",
    "helmet": "7.1.0",
    "morgan": "1.10.0"
  },
  "devDependencies": {
    "nodemon": "3.0.3",
    "jest": "29.7.0",
    "supertest": "6.3.4",
    "mongodb-memory-server": "9.1.6",
    "@babel/preset-env": "7.23.9",
    "babel-jest": "29.7.0"
  },
  "jest": {
    "testEnvironment": "node",
    "transform": {
      "^.+\\.js$": "babel-jest"
    },
    "testMatch": [
      "**/tests/**/*.test.js"
    ]
  },
  "babel": {
    "presets": [
      ["@babel/preset-env", { "targets": { "node": "current" } }]
    ]
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
